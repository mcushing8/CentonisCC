// This file defines Firestore security rules for personal and team access.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function membershipDocId(teamId, userId) {
      return teamId + "_" + userId;
    }

    function isTeamMember(teamId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/teamMemberships/$(membershipDocId(teamId, request.auth.uid)));
    }

    function isTeamOwner(teamId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/teamMemberships/$(membershipDocId(teamId, request.auth.uid))).data.role == "owner";
    }

    function isPersonalWorkspace(workspaceType, workspaceId) {
      return workspaceType == "personal" && workspaceId == request.auth.uid;
    }

    function isTeamWorkspace(workspaceType, workspaceId) {
      return workspaceType == "team" && isTeamMember(workspaceId);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /teams/{teamId} {
      allow read: if isTeamMember(teamId);
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update, delete: if isTeamOwner(teamId);
    }

    match /teamMemberships/{membershipId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() &&
        request.resource != null &&
        isTeamOwner(request.resource.data.teamId);
      allow delete: if isSignedIn() && isTeamOwner(resource.data.teamId);
    }

    match /goals/{goalId} {
      allow read: if isSignedIn() && (
        isPersonalWorkspace(resource.data.workspaceType, resource.data.workspaceId) ||
        isTeamWorkspace(resource.data.workspaceType, resource.data.workspaceId)
      );
      allow create: if isSignedIn() && (
        isPersonalWorkspace(request.resource.data.workspaceType, request.resource.data.workspaceId) ||
        isTeamWorkspace(request.resource.data.workspaceType, request.resource.data.workspaceId)
      );
      allow update, delete: if isSignedIn() && (
        isPersonalWorkspace(resource.data.workspaceType, resource.data.workspaceId) ||
        isTeamWorkspace(resource.data.workspaceType, resource.data.workspaceId)
      );
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        isPersonalWorkspace(resource.data.workspaceType, resource.data.workspaceId) ||
        isTeamWorkspace(resource.data.workspaceType, resource.data.workspaceId)
      );
      allow create: if isSignedIn() && (
        isPersonalWorkspace(request.resource.data.workspaceType, request.resource.data.workspaceId) ||
        isTeamWorkspace(request.resource.data.workspaceType, request.resource.data.workspaceId)
      );
      allow update, delete: if isSignedIn() && (
        isPersonalWorkspace(resource.data.workspaceType, resource.data.workspaceId) ||
        isTeamWorkspace(resource.data.workspaceType, resource.data.workspaceId)
      );
    }

    match /comments/{commentId} {
      allow read: if isSignedIn() && (
        isPersonalWorkspace(resource.data.workspaceType, resource.data.workspaceId) ||
        isTeamWorkspace(resource.data.workspaceType, resource.data.workspaceId)
      );
      allow create: if isSignedIn() && (
        isPersonalWorkspace(request.resource.data.workspaceType, request.resource.data.workspaceId) ||
        isTeamWorkspace(request.resource.data.workspaceType, request.resource.data.workspaceId)
      );
      allow update, delete: if false;
    }
  }
}
