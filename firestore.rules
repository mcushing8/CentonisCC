rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function memberDocId(workspaceId, userId) {
      return workspaceId + "_" + userId;
    }

    function isWorkspaceMember(workspaceId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/workspaceMembers/$(memberDocId(workspaceId, request.auth.uid)));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMember(workspaceId);
      allow create: if isSignedIn();
      allow update: if isWorkspaceMember(workspaceId);
      allow delete: if isSignedIn() && resource.data.createdByUserId == request.auth.uid;
    }

    match /workspaceMembers/{membershipId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isWorkspaceMember(resource.data.workspaceId)
      );
    }

    match /dailyTasks/{taskId} {
      allow read: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);
      allow create: if isSignedIn() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update, delete: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);
    }

    match /databaseEntries/{entryId} {
      allow read: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);
      allow create: if isSignedIn() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update, delete: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);
    }

    match /projects/{projectId} {
      allow read: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);
      allow create: if isSignedIn() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update, delete: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);
    }

    match /notes/{noteId} {
      allow read: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);
      allow create: if isSignedIn() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update, delete: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);
    }

    match /noteFolders/{folderId} {
      allow read: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);
      allow create: if isSignedIn() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update, delete: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);
    }
  }
}
