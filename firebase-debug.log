[debug] [2026-03-02T08:39:45.090Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/centoniscc/rulesets {"name":"projects/centoniscc/rulesets/6ef9a9c7-53fa-4f1c-9cb1-fc73e39e4f90","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function memberDocId(workspaceId, userId) {\n      return workspaceId + \"_\" + userId;\n    }\n\n    function isWorkspaceMember(workspaceId) {\n      return isSignedIn() &&\n        exists(/databases/$(database)/documents/workspaceMembers/$(memberDocId(workspaceId, request.auth.uid)));\n    }\n\n    match /users/{userId} {\n      allow read: if isSignedIn();\n      allow write: if isSignedIn() && request.auth.uid == userId;\n    }\n\n    match /workspaces/{workspaceId} {\n      allow read: if isWorkspaceMember(workspaceId);\n      allow create: if isSignedIn();\n      allow update: if isWorkspaceMember(workspaceId);\n      allow delete: if isSignedIn() && resource.data.createdByUserId == request.auth.uid;\n    }\n\n    match /workspaceMembers/{membershipId} {\n      allow read: if isSignedIn();\n      allow create: if isSignedIn();\n      allow delete: if isSignedIn() && (\n        resource.data.userId == request.auth.uid ||\n        isWorkspaceMember(resource.data.workspaceId)\n      );\n    }\n\n    match /dailyTasks/{taskId} {\n      allow read: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);\n      allow create: if isSignedIn() && isWorkspaceMember(request.resource.data.workspaceId);\n      allow update, delete: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);\n    }\n\n    match /databaseEntries/{entryId} {\n      allow read: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);\n      allow create: if isSignedIn() && isWorkspaceMember(request.resource.data.workspaceId);\n      allow update, delete: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);\n    }\n\n    match /projects/{projectId} {\n      allow read: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);\n      allow create: if isSignedIn() && isWorkspaceMember(request.resource.data.workspaceId);\n      allow update, delete: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);\n    }\n\n    match /notes/{noteId} {\n      allow read: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);\n      allow create: if isSignedIn() && isWorkspaceMember(request.resource.data.workspaceId);\n      allow update, delete: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);\n    }\n\n    match /noteFolders/{folderId} {\n      allow read: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);\n      allow create: if isSignedIn() && isWorkspaceMember(request.resource.data.workspaceId);\n      allow update, delete: if isSignedIn() && isWorkspaceMember(resource.data.workspaceId);\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-02T08:39:45.072159Z","metadata":{"services":["cloud.firestore"]}}
